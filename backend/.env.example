# ══════════════════════════════════════════════════════════
# Astra Backend – Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.
# ══════════════════════════════════════════════════════════

# ── Umgebung ─────────────────────────────────────────────
# Moegliche Werte: development | testing | production
APP_ENV=development
FLASK_ENV=development
FLASK_APP=run.py

# ── Secrets (PFLICHT in Produktion!) ─────────────────────
# Generieren z.B. mit: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret

# ── Datenbank ────────────────────────────────────────────
# Fuer Produktion PostgreSQL verwenden:
DATABASE_URL=postgresql://astra:astra@localhost:5432/astra
# Fuer Entwicklung mit SQLite:
# DATABASE_URL=sqlite:///astra.db

# ── Redis / Cache / Queue ────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TYPE=simple
# CACHE_REDIS_URL=redis://localhost:6379/1

# ── Runner / Wings ───────────────────────────────────────
# "stub" fuer Entwicklung ohne Wings, "wings" fuer Produktion
RUNNER_ADAPTER=stub
RUNNER_TIMEOUT_CONNECT=5
RUNNER_TIMEOUT_READ=30
RUNNER_DEBUG=false

# ── Webhook-Retry ────────────────────────────────────────
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAYS=5,15,30
WEBHOOK_REQUEST_TIMEOUT=10

# ── Auth / JWT / MFA ─────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
MFA_ISSUER_NAME=Astra
MAX_API_KEYS_PER_USER=10

# ── CORS / Hosts / URLs ─────────────────────────────────
# Kommaseparierte Origins, z.B.: https://astra.example.com
CORS_ORIGINS=*
ALLOWED_HOSTS=*
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ── Reverse Proxy (Nginx / Caddy / Traefik) ─────────────
# Aktivieren wenn Astra hinter einem Reverse Proxy laeuft
PROXY_FIX_ENABLED=false
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=0
PROXY_FIX_X_PREFIX=0
TRUSTED_PROXIES=127.0.0.1

# ── Secure Cookies (fuer HTTPS) ─────────────────────────
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

# ── Rate Limiting ────────────────────────────────────────
RATELIMIT_ENABLED=true
RATELIMIT_AUTH_PER_MINUTE=20

# ── Logging ──────────────────────────────────────────────
# Moegliche Werte: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# LOG_FORMAT=%(asctime)s [%(levelname)s] %(name)s: %(message)s

# ── Betrieb ──────────────────────────────────────────────
MAINTENANCE_MODE=false
